<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_tree_info.xml
    Defines the tree detail dialog-style screen launched when a green dot marker is tapped.
    The layout is intentionally narrow (310dp) to appear as a popup panel rather than a
    full-screen activity.

    Root ConstraintLayout: no fixed height — the outer container sizes to the ScrollView.

    ScrollView:
      width=310dp — panel width chosen to look like an overlay dialog.
      height=0dp + constraintHeight_max=450dp + constrainedHeight=true — allows the ScrollView
      to grow up to 450dp tall but never taller, ensuring it fits on small screens.
      paddingTop=20dp, paddingBottom=30dp, clipToPadding=false — extra padding at top and bottom
      so content doesn't abut the panel edges while the last item can still be scrolled into view.

    Inner ConstraintLayout (id=main, marginHorizontal=20dp):
      Chains all TextViews top-to-bottom. Each view is constrained to the bottom of the view
      above it using layout_marginTop for spacing.

    commonName: 25sp white, centered — the primary tree identification label.
    botanicalName: 20sp italic, centered — scientific name displayed below the common name.
    distance: 16sp accent_color — shown or hidden by TreeInfoActivity depending on GPS availability.
    family, nativeOrCultivated, wildlife, fallColors, flowers, dbh, height:
      15sp default color — pre-labeled fields; TreeInfoActivity prepends the label and appends the value.
    description: 15sp italic — the full prose description from strings.xml; hidden if empty.
    mortonLink: 15sp — styled as a clickable link by TreeInfoActivity; hidden if no Morton page exists.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TreeInfoActivity">

    <!-- 310dp wide ScrollView capped at 450dp tall — appears as a dialog panel over the map -->
    <ScrollView
        android:layout_width="310dp"
        android:layout_height="0dp"
        android:paddingTop="20dp"
        android:paddingBottom="30dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintHeight_max="450dp"
        app:layout_constrainedHeight="true">

        <!-- Inner ConstraintLayout chains all tree detail fields vertically with 20dp horizontal margin -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp">

            <!-- Common (everyday) name — 25sp white, centered at the top of the panel -->
            <TextView
                android:id="@+id/commonName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="25sp"
                android:textColor="@color/white"
                android:text="[Common name]"
                android:textAlignment="center"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Botanical (scientific) name — italic to follow the standard scientific naming convention -->
            <TextView
                android:id="@+id/botanicalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="italic"
                android:text="[Botanical name]"
                android:textAlignment="center"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/commonName" />

            <!-- Distance from user to tree — accent_color, 10dp below botanicalName.
                 TreeInfoActivity sets this to a formatted metres string or hides it if no GPS fix. -->
            <TextView
                android:id="@+id/distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:text="Could not get distance"
                android:textColor="?attr/accent_color"
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/botanicalName" />

            <!-- Tree family — label "Family: " prepended; filled with common+botanical family by TreeInfoActivity -->
            <TextView
                android:id="@+id/family"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Family: "
                android:layout_marginTop="20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/distance" />

            <!-- Native vs. cultivated origin — from the CSV nativeOrCultivated column -->
            <TextView
                android:id="@+id/nativeOrCultivated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Native or cultivated: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/family" />

            <!-- Wildlife value of the tree — from the CSV wildlife column -->
            <TextView
                android:id="@+id/wildlife"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Wildlife: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nativeOrCultivated" />

            <!-- Fall foliage color — from the CSV fallColors column -->
            <TextView
                android:id="@+id/fallColors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Fall colors: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/wildlife" />

            <!-- Flower description — from the CSV flowers column -->
            <TextView
                android:id="@+id/flowers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Flowers: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fallColors" />

            <!-- Diameter at breast height — standard forestry trunk width measurement from the CSV -->
            <TextView
                android:id="@+id/dbh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="DBH: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/flowers" />

            <!-- Tree height in feet — from the CSV height column -->
            <TextView
                android:id="@+id/height"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Height: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dbh" />

            <!-- Prose description from strings.xml — italic, 20dp below height.
                 TreeInfoActivity hides this view if the description string is empty. -->
            <TextView
                android:id="@+id/description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="italic"
                android:layout_marginTop="20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/height" />

            <!-- Morton Arboretum page link — styled as a blue clickable Spannable by TreeInfoActivity.
                 Hidden (GONE) if getMortonPageName() returns an empty string for this species. -->
            <TextView
                android:id="@+id/mortonLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginTop="20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/description" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
