<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    android:padding="40dp"
    android:background="?attr/background_color"
    tools:context=".TreeInfo">

    <TextView
        android:id="@+id/commonName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/logo_color"
        android:text="[Common name]"
        android:gravity="center"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/botanicalName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="?attr/logo_color"
        android:alpha="0.8"
        android:text="[Botanical name]"
        android:gravity="center"
        android:textStyle="italic"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/commonName" />

    <TextView
        android:id="@+id/family"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="Family: "
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/botanicalName" />

    <TextView
        android:id="@+id/nativeOrCultivated"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="Native or cultivated: "
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/family" />

    <TextView
        android:id="@+id/wildlife"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="Wildlife: "
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nativeOrCultivated" />

    <TextView
        android:id="@+id/fallColors"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="Fall colors: "
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/wildlife" />

    <TextView
        android:id="@+id/flowers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="Flowers: "
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fallColors" />

    <TextView
        android:id="@+id/dbh"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="DBH: "
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/flowers" />

    <TextView
        android:id="@+id/height"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:text="Height: "
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dbh" />

    <TextView
        android:id="@+id/description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:textStyle="italic"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="8dp"
        android:lineSpacingExtra="6dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/height" />

    <TextView
        android:id="@+id/mortonLink"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="?attr/logo_color"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/description" />

</androidx.constraintlayout.widget.ConstraintLayout>
