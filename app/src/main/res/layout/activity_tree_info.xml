<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_tree_info.xml
    This layout defines the detail panel that appears when a user selects a tree on the map.
    It is designed to look like a floating dialog, providing a rich set of forestry data
    in a compact, scrollable format.
-->

<!--
    Root Container: ConstraintLayout
    - Using a ConstraintLayout at the root ensures a flat view hierarchy. This is particularly
      important for this screen because it is often launched as a transparent overlay on top
      of the MapView. A flat hierarchy reduces the rendering load on the main thread.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TreeInfoActivity">

    <!--
        Dialog Panel: ScrollView
        - android:layout_width="310dp": This fixed width creates the "panel" effect,
          ensuring the map remains partially visible in the background.
        - app:layout_constraintHeight_max="450dp" & app:layout_constrainedHeight="true":
          This is an advanced ConstraintLayout configuration. It allows the ScrollView to
          shrink to fit its content ("wrap_content"), but prevents it from growing beyond
          450dp. This ensures the dialog stays manageable even with long descriptions.
        - android:clipToPadding="false": Allows content to scroll into the padding area
          for a smoother visual experience.
    -->
    <ScrollView
        android:layout_width="310dp"
        android:layout_height="0dp"
        android:paddingTop="20dp"
        android:paddingBottom="30dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintHeight_max="450dp"
        app:layout_constrainedHeight="true">

        <!--
            Inner Content Container:
            - Chains all tree details vertically.
            - android:layout_marginHorizontal="20dp" provides internal gutters.
        -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp">

            <!--
                Common Name:
                - The primary identifier for the tree.
                - 25sp bold white text provides high visibility against the dark background.
            -->
            <TextView
                android:id="@+id/commonName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="25sp"
                android:textColor="@color/white"
                android:text="[Common name]"
                android:textAlignment="center"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!--
                Botanical Name:
                - android:textStyle="italic": Follows the standard scientific naming convention.
                - Secondary font size (20sp) creates a clear typographic hierarchy.
            -->
            <TextView
                android:id="@+id/botanicalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="italic"
                android:text="[Botanical name]"
                android:textAlignment="center"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/commonName" />

            <!--
                Proximity Data:
                - textColor="?attr/accent_color": The seasonal accent color highlights the
                  dynamic distance calculation to draw the user's attention.
                - TreeInfoActivity dynamically formats this string in real-time.
            -->
            <TextView
                android:id="@+id/distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:text="Could not get distance"
                android:textColor="?attr/accent_color"
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/botanicalName" />

            <!--
                Forestry Data Fields:
                - Each TextView below corresponds to a specific column in the tree database CSV.
                - MarginTop="10dp" maintains even vertical rhythm between data points.
            -->

            <!-- Taxonomic Family information. -->
            <TextView
                android:id="@+id/family"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Family: "
                android:layout_marginTop="20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/distance" />

            <!-- Indicates if the species is indigenous to the area. -->
            <TextView
                android:id="@+id/nativeOrCultivated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Native or cultivated: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/family" />

            <!-- Ecological benefit/Wildlife interaction details. -->
            <TextView
                android:id="@+id/wildlife"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Wildlife: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nativeOrCultivated" />

            <!-- Description of fall foliage appearance. -->
            <TextView
                android:id="@+id/fallColors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Fall colors: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/wildlife" />

            <!-- Seasonal flowering details. -->
            <TextView
                android:id="@+id/flowers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Flowers: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/fallColors" />

            <!-- DBH: Diameter at Breast Height (standard forestry measurement). -->
            <TextView
                android:id="@+id/dbh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="DBH: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/flowers" />

            <!-- Recorded height of the tree specimen. -->
            <TextView
                android:id="@+id/height"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Height: "
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dbh" />

            <!--
                Detailed Description:
                - Italicized to differentiate descriptive prose from the structured data above.
                - TreeInfoActivity sets visibility to GONE if no description is available.
            -->
            <TextView
                android:id="@+id/description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="italic"
                android:layout_marginTop="20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/height" />

            <!--
                External Educational Link:
                - This TextView is transformed into a clickable hyperlink by the Activity.
                - It directs users to the Morton Arboretum website for deep-dive learning.
            -->
            <TextView
                android:id="@+id/mortonLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginTop="20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/description" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
