<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_delete_confirm.xml
    This layout defines the user interface for the delete confirmation bottom sheet.
    It is designed to provide a clear, high-contrast warning to the user before they
    perform a permanent and destructive action (deleting a post).
-->

<!--
    Root Container: LinearLayout
    - A vertical LinearLayout is used here because the elements (icon, title, subtitle,
      and buttons) follow a simple, linear top-to-bottom stack.
    - android:padding="32dp": Provides extra internal spacing to make the dialog
      feel spacious and important, matching the gravity of the "Delete" action.
    - android:background="?attr/background_color": Dynamically retrieves the seasonal
      theme color to ensure the dialog matches the rest of the application's UI.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="?attr/background_color">

    <!--
        Destructive Icon Header: FrameLayout
        - FrameLayout is used to layer two views on top of each other.
        - The solid red circle (@drawable/delete_icon_bg) acts as the background layer,
          immediately signaling "danger" or "warning" to the user.
        - The ImageView floats centered on top, providing the specific "Delete" context.
    -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp">

        <!-- Visual warning: Red circular background. -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/delete_icon_bg" />

        <!-- Semantic icon: Outlined delete bucket. -->
        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_delete_outline"
            android:contentDescription="Delete" />

    </FrameLayout>

    <!--
        Title: "Delete Post?"
        - Phrased as a direct question to the user, forcing a conscious decision.
        - 22sp bold: Large enough to be the primary focus after the icon header.
    -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete Post?"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <!--
        Warning Subtitle:
        - Explains the consequence of the action (irreversibility).
        - textColor="#99FFFFFF": A slightly transparent white color is used to
          reduce visual weight, making it secondary to the title.
    -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This action cannot be undone.\nYour post will be permanently removed."
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!--
        "Delete" Primary Action (Destructive):
        - app:backgroundTint="#E53935": A bright red color is used specifically for
          destructive actions to separate it from the app's standard seasonal accent.
        - 52dp height: Provides a large, accessible touch target.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_delete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Delete"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#E53935"
        app:cornerRadius="10dp"
        android:layout_marginBottom="8dp" />

    <!--
        "Cancel" Secondary Action (Safe Exit):
        - style="...Button.TextButton": An outlined or text-style button is used to
          visually deprioritize this action compared to the primary "Delete" button.
        - app:strokeColor="?attr/accent_color": The border color matches the current
          seasonal theme, signaling that this is the "standard" or "safe" path.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel_delete"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:textSize="16sp"
        android:text="Cancel"
        android:textColor="?attr/accent_color"
        app:strokeColor="?attr/accent_color"
        app:strokeWidth="1.5dp"
        app:cornerRadius="10dp" />

</LinearLayout>
