<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_sign_up.xml
    This layout defines the user interface for the account creation (Sign Up) screen.
    It utilizes Material Design components and a flat view hierarchy to provide a
    modern, responsive, and seasonal-themed onboarding experience.
-->

<!--
    Root Container: ConstraintLayout
    - Selected as the root to maintain a flat view hierarchy. By avoiding nested view groups,
      the Android system can measure and lay out the entire screen in fewer passes, which
      optimizes UI performance and reduces battery consumption during rendering.
    - android:background="?attr/background_color": Dynamically retrieves the base color
      defined in the current active seasonal theme (Spring, Summer, Autumn, Winter).
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp"
    tools:context=".SignUpActivity">

    <!--
        Primary Heading: "Create Account"
        - 32sp bold: Establishes clear visual hierarchy as the primary identifier for this task.
        - textColor="?attr/alt_color": Uses the "alternate" seasonal accent color to
          visually distinguish the sign-up flow from the primary login screen.
    -->
    <TextView
        android:id="@+id/signUpTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Create Account"
        android:textColor="?attr/alt_color"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Subtitle: "Join the urban forestry community"
        - textColor="@color/white": Provides a clean, subordinate element to the bold title.
        - 16sp: Follows standard typography scales for body/subtitle text.
    -->
    <TextView
        android:id="@+id/signUpSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Join the urban forestry community"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signUpTitle" />

    <!--
        Full Name Input Field:
        - TextInputLayout (OutlinedBox): Provides the floating label behavior and an animated
          border that signals focus. The Outlined style is chosen for better input definition.
        - app:boxStrokeColor="?attr/accent_color": The border glows with the seasonal primary
          accent color when the user interacts with it.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/nameInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Full Name"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/signUpSubtitle">

        <!--
            - android:inputType="textPersonName": Optimizes the keyboard for name entry by
              automatically enabling Title Case (capitalizing the first letter of each word).
            - android:minHeight="60dp": Ensures a large touch target area for accessibility.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/nameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:inputType="textPersonName"
            android:textColor="@color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Username Input Field:
        - Positioned 16dp below the name field to create a logical grouping of identity fields.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/usernameInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Username"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/nameInputLayout">

        <!--
            - android:inputType="text": Standard text input used for unique handles;
              avoids automatic capitalization found in person names.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/usernameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:inputType="text"
            android:textColor="@color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Email Input Field:
        - MaterialAutoCompleteTextView: This is a complex detail. Unlike a standard text field,
          this allows SignUpActivity to attach an ArrayAdapter that suggests common email
          domains (@gmail.com, @yahoo.com, etc.) as the user types, speeding up the process.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/emailInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Email"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/usernameInputLayout">

        <!--
            - android:inputType="textEmailAddress": Changes the keyboard layout to show
              the "@" and "." symbols as primary keys.
            - android:popupBackground="?attr/background_color": Ensures the domain suggestion
              dropdown menu matches the seasonal theme background color.
        -->
        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/emailEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:inputType="textEmailAddress"
            android:textColor="@color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:popupBackground="?attr/background_color" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Password Input Field:
        - app:passwordToggleEnabled="true": Adds the standard Material visibility toggle,
          allowing users to verify their password during account creation to prevent errors.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Password"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/emailInputLayout"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/white">

        <!--
            - android:inputType="textPassword": Masks input characters and secures the
              field from being copied to the clipboard.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/passwordEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        "Sign Up" Primary Action Button:
        - backgroundTint="?attr/accent_color": The primary seasonal highlight color signals
          the most important call-to-action on the screen.
        - android:layout_height="60dp": Provides a large touch target for accessibility.
        - android:textColor="?attr/background_color": For optimal contrast, the button text
          adopts the theme's background color to stand out against the tinted button.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/signUpButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="?attr/accent_color"
        android:text="Sign Up"
        android:textColor="?attr/background_color"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/passwordInputLayout" />

    <!--
        Navigation Link: "Already have an account? Log in"
        - textColor="?attr/alt_color": Using the alternate accent color ties this link back
          to the screen's title, creating a unified secondary visual theme for sign-up.
    -->
    <TextView
        android:id="@+id/goToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Already have an account? Log in"
        android:textColor="?attr/alt_color"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signUpButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
