<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_feed.xml
    This layout defines the community feed screen. It is designed to be the central hub
    where users browse content posted by others. It balances a static header area with
    a dynamic, scrollable list.
-->

<!--
    Root Container: ConstraintLayout
    - ConstraintLayout is the industry standard for complex Android layouts. It allows for
      defining a view's position relative to others, which keeps the view hierarchy flat.
    - A flat hierarchy is critical for performance as it minimizes the number of nested
      measurement passes during rendering.
    - android:fitsSystemWindows="true": This attribute ensures that the layout accounts
      for system UI elements like the status bar and navigation bar, preventing content
      from being drawn behind them.
    - android:background="?attr/background_color_emphasis": Uses a seasonal theme attribute.
      The "emphasis" variant is typically used for header or background areas to provide
      subtle visual contrast from the main content lists.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/background_color_emphasis">

    <!--
        Heading: "Community Feed"
        - This TextView serves as the primary visual anchor for the screen.
        - textColor="?attr/accent_color": Dynamically adapts to the current season's
          primary highlight color (e.g., deep orange in autumn).
        - app:layout_constraintTop_toTopOf="parent": Anchors the title to the top,
          respecting the system window insets provided by fitsSystemWindows.
    -->
    <TextView
        android:id="@+id/feedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Community Feed"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Profile Navigation Button: ShapeableImageView
        - ShapeableImageView is a powerful Material Component that allows for dynamic
          clipping of images without needing custom drawables.
        - app:shapeAppearanceOverlay="@style/ShapeAppearance.UrbanForestry.Circle":
          This specific overlay clips the square image into a perfect circle.
        - app:strokeWidth="2dp" and app:strokeColor="?attr/accent_color": Adds a branded
          ring around the profile picture to make it pop against the background.
        - android:background="?attr/selectableItemBackgroundBorderless": Provides a
          circular Material touch ripple when the user interacts with the button.
    -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/profile_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:padding="4dp"
        android:src="@mipmap/default_pfp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerCrop"
        android:clickable="true"
        android:focusable="true"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.UrbanForestry.Circle"
        app:strokeColor="?attr/accent_color"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Community Content List: RecyclerView
        - RecyclerView is highly optimized for displaying long lists. It "recycles"
          item views as they scroll off-screen, maintaining low memory usage.
        - layout_height="0dp" (match_constraint): This allows the list to dynamically
          stretch to fill the space between the header and the bottom of the screen.
        - android:clipToPadding="false": This is a crucial UX detail. It allows the
          posts to scroll underneath the padding at the bottom, ensuring that the last
          post is not permanently obscured by the FloatingActionButton.
        - android:background="?attr/background_color": Uses the base seasonal color,
          creating a subtle layered effect against the "emphasis" header background.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        android:layout_marginTop="20dp"
        android:background="?attr/background_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/feedTitle" />

    <!--
        Visual Separator:
        - A 1dp high View acts as a hairline divider between the static title area
          and the dynamic scrollable list.
        - android:background="?attr/accent_color": Tying the divider into the theme
          colors provides a cohesive, polished look.
    -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/accent_color"
        app:layout_constraintTop_toTopOf="@id/recyclerView" />

    <!--
        Create Post Button: FloatingActionButton (FAB)
        - The FAB represents the primary action on this screen: contributing to the feed.
        - app:backgroundTint="?attr/accent_color": Signals importance via theme accents.
        - Positioned with a 24dp margin from the bottom-right, following standard
          Material Design patterns for accessibility and ergonomics.
    -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Add Post"
        android:src="@drawable/ic_add"
        app:tint="?attr/background_color"
        app:backgroundTint="?attr/accent_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
