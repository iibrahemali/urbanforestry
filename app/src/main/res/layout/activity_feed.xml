<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_feed.xml
    Defines the community feed screen: a centered title, a circular profile image
    button in the top-right corner, a full-height scrollable post list, a thin
    accent-colored divider at the top of the list, and a FloatingActionButton
    in the bottom-right corner to create new posts.
    fitsSystemWindows="true" on the root reserves space for the status bar so the
    title is not hidden behind it.
    background_color_emphasis gives the header area a slightly different shade from
    background_color on the RecyclerView, creating a subtle depth effect.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/background_color_emphasis">

    <!-- "Community Feed" heading centered at the top of the screen.
         accent_color text makes it the dominant visual anchor, consistent with all other screen titles.
         24dp marginTop keeps it below the status bar area that fitsSystemWindows reserved. -->
    <TextView
        android:id="@+id/feedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Community Feed"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Circular profile picture button in the top-right corner.
         ShapeableImageView + ShapeAppearance.UrbanForestry.Circle clips the image to a perfect circle.
         FeedActivity loads the real profile picture via Glide; the default_pfp mipmap shows until it loads.
         selectableItemBackgroundBorderless produces a circular ripple on tap without a rectangular outline.
         The accent-colored 2dp stroke visually ties the button to the title and divider. -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/profile_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:padding="4dp"
        android:src="@mipmap/default_pfp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerCrop"
        android:clickable="true"
        android:focusable="true"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.UrbanForestry.Circle"
        app:strokeColor="?attr/accent_color"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable list of posts filling all remaining vertical space.
         0dp width and height with four constraints means ConstraintLayout fills the available space.
         clipToPadding=false lets the last card scroll fully out from behind the FAB.
         background_color is slightly different from background_color_emphasis above, creating a
         subtle layered look between the header area and the list. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        android:layout_marginTop="20dp"
        android:background="?attr/background_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/feedTitle" />

    <!-- Thin hairline divider at the top edge of the RecyclerView.
         1dp height is the standard Material Design separator thickness.
         Aligned to the RecyclerView's top so it appears as the list's visual border. -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/accent_color"
        app:layout_constraintTop_toTopOf="@id/recyclerView" />

    <!-- "+" FloatingActionButton to open CreatePostActivity.
         FeedActivity fades this to 25% alpha when the user scrolls to the bottom of the list
         so it doesn't permanently obscure the last post.
         bottom+end constraints with 24dp margin position it in the classic FAB location. -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Add Post"
        android:src="@drawable/ic_add"
        app:tint="?attr/background_color"
        app:backgroundTint="?attr/accent_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
