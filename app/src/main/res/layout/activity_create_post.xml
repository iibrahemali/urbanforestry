<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_create_post.xml
    This layout serves as a "gateway" or "chooser" screen, allowing users to select
    between two different types of posts: an image-based post or a text-only post.
-->

<!--
    Root Container: ConstraintLayout
    - This allows for a flat view hierarchy, reducing UI overdraw and improving rendering
      speed by avoiding deep nesting of layouts.
    - android:background="?attr/background_color": Retrieves the color from the current
      seasonal theme (e.g., green for spring, orange for autumn), ensuring the app
      remains visually dynamic throughout the year.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp">

    <!--
        Title: "Create a Post"
        - The vertical position is established using a large layout_marginTop="225dp",
          centering the group of elements in the middle of the screen's height.
        - textColor="?attr/accent_color": Matches the primary accent of the active season.
    -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create a Post"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="225dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_camera"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Camera Button (Primary Action):
        - style="@style/Widget.MaterialComponents.Button": A solid, filled button
          representing the primary way to share content (via camera).
        - android:layout_height="60dp": Provides a large, accessible touch target.
        - android:backgroundTint="?attr/accent_color": The primary seasonal highlight color.
        - android:textColor="?attr/background_color": Inverting the colors ensures text
          legibility against the high-contrast button background.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_camera"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Take a picture"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/background_color"
        android:backgroundTint="?attr/accent_color"
        android:layout_marginTop="64dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <!--
        Text Post Button (Secondary Action):
        - style="@style/Widget.MaterialComponents.Button.OutlinedButton": The outlined
          look visually demotes this action compared to the solid camera button,
          guiding users toward image-sharing while still providing a clear secondary option.
        - app:strokeColor="?attr/accent_color": The border color follows the theme.
        - app:layout_constraintTop_toBottomOf="@id/btn_camera": Chains this button to
          the bottom of the primary action.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_text"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Write a text post"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="48dp"
        app:cornerRadius="12dp"
        app:strokeColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/btn_camera"
        android:layout_marginBottom="48dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
