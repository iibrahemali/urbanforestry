<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_edit_profile.xml
    This layout defines the user interface for modifying profile information.
    It emphasizes data entry with Material Design TextInputLayouts and provides
    clear primary and secondary actions.
-->

<!--
    Root: ConstraintLayout
    - This container is used to build a flexible and responsive UI without nesting multiple
      layouts, which optimizes the rendering pipeline by keeping the view hierarchy flat.
    - android:background="?attr/background_color": Dynamically resolves to a specific color
      based on the user's active seasonal theme (e.g., deep winter blue or spring green).
    - android:padding="24dp": Provides consistent whitespace around the screen edges.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp"
    tools:context=".EditProfileActivity">

    <!--
        Heading: "Edit Profile"
        - 28sp bold accent color: Establishes a clear visual hierarchy as the primary screen title.
        - app:layout_constraintTop_toTopOf="parent": Anchors the title to the top with a 32dp margin.
        - Horizontal centering is achieved by constraining both start and end to the parent.
    -->
    <TextView
        android:id="@+id/editProfileTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Edit Profile"
        android:textColor="?attr/accent_color"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Full Name Input Field:
        - style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox": Implements the
          modern OutlinedBox design which is clearer and more accessible than traditional underlined fields.
        - app:boxStrokeColor="?attr/accent_color": The border color changes to the seasonal highlight
          when the field is focused, providing active visual feedback.
        - The EditProfileActivity pre-fills this from Intent extras passed by ProfileActivity.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/editNameInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Full Name"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/editProfileTitle">

        <!--
            android:inputType="textPersonName": Specifically triggers the keyboard to
            capitalize the first letter of each word (Title Case) and provides optimized
            auto-completion for names.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Username Input Field:
        - Chains vertically to the bottom of the Name field with a 16dp margin.
        - Uses consistent styling to maintain the design system's integrity.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/editUsernameInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Username"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/editNameInputLayout">

        <!--
            android:inputType="text": General text input that preserves casing,
            ideal for unique handles or usernames.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editUsernameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Bio Input Field (Text Area):
        - A multi-line variant of the outlined box, providing a larger area for longer descriptions.
        - EditProfileActivity dynamically loads this value from Firestore on initialization.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/editBioInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Bio"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/editUsernameInputLayout">

        <!--
            - android:inputType="textMultiLine": Enables the 'Enter' key to insert newlines
              rather than submitting the form.
            - android:minLines="3": Reserves space for three lines of text, signaling to the
              user that a longer entry is expected.
            - android:gravity="top": Ensures the cursor starts at the top-left corner,
              following standard text area behavior.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editBioEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        "Save Changes" Primary Action:
        - The filled background style (backgroundTint="?attr/accent_color") establishes
          strong visual weight, indicating this is the primary path to completion.
        - app:cornerRadius="10dp": Matches the curvature used across the app's button system.
        - android:textColor="?attr/background_color": Ensures accessibility by providing
          high contrast against the bright accent-colored button background.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveProfileButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="?attr/accent_color"
        android:text="Save Changes"
        android:textColor="?attr/background_color"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="10dp"
        app:layout_constraintTop_toBottomOf="@id/editBioInputLayout" />

    <!--
        "Cancel" Secondary Action:
        - style="@style/Widget.MaterialComponents.Button.TextButton": A lower-emphasis
          button style without a background fill. This hierarchy prevents the user from
          becoming overwhelmed by multiple competing high-intensity actions.
        - Chained directly below the primary button for a clear vertical task flow.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelEditButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="Cancel"
        android:textSize="16sp"
        android:textColor="?attr/accent_color"
        app:cornerRadius="10dp"
        app:layout_constraintTop_toBottomOf="@id/saveProfileButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
