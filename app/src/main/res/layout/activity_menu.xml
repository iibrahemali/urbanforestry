<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    tools:context=".Menu">

    <Button
        android:id="@+id/signOutButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/background_color"
        android:padding="12dp"
        android:text="Sign Out"
        android:textColor="@color/logo_color"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_logout"
        app:iconTint="@color/logo_color"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/logo_color"
        app:strokeWidth="1dp" />

    <Button
        android:id="@+id/aboutButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/background_color"
        android:padding="12dp"
        android:text="About"
        android:textColor="@color/logo_color"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signOutButton"
        app:strokeColor="@color/logo_color"
        app:strokeWidth="1dp" />

    <Button
        android:id="@+id/cameraButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/background_color"
        android:padding="12dp"
        android:text="Camera"
        android:textColor="@color/logo_color"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_camera"
        app:iconTint="@color/logo_color"
        app:layout_constraintEnd_toStartOf="@id/signOutButton"
        app:layout_constraintTop_toTopOf="@id/signOutButton"
        app:layout_constraintBottom_toBottomOf="@id/signOutButton"
        app:strokeColor="@color/logo_color"
        app:strokeWidth="1dp" />


    <Button
        android:id="@+id/gameButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/background_color"
        android:padding="12dp"
        android:text="Game"
        android:textColor="@color/logo_color"
        app:cornerRadius="12dp"
        app:iconTint="@color/logo_color"
        app:layout_constraintEnd_toStartOf="@id/cameraButton"
        app:layout_constraintTop_toTopOf="@id/signOutButton"
        app:layout_constraintBottom_toBottomOf="@id/signOutButton"
        app:strokeColor="@color/logo_color"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/gameGoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/gameButton"
        app:layout_constraintLeft_toLeftOf="@id/gameButton" />

    <TextView
        android:id="@+id/goalProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/gameButton"
        app:layout_constraintStart_toEndOf="@id/gameGoal" />

</androidx.constraintlayout.widget.ConstraintLayout>