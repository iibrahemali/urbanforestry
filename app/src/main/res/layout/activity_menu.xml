<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_menu.xml
    This layout defines the overlay menu, which typically appears as a modal dialog or
    a side-drawer style panel. It serves as the primary navigation and configuration
    hub for the user's active session.
-->

<!--
    Root Container: ConstraintLayout
    - android:layout_width="310dp": A fixed width is used instead of "match_parent" to create
      a panel-like appearance. This ensures the menu looks consistent across different
      screen sizes (phones vs. tablets) without filling the entire display.
    - ConstraintLayout enables precise relative positioning, which is ideal for the
      vertical stacking of diverse UI elements like mission goals, settings, and buttons.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="310dp"
    android:layout_height="wrap_content"
    tools:context=".MenuActivity">

    <!--
        Inner ConstraintLayout:
        - android:padding="20dp": Provides internal breathing room for all child views.
        - Using a nested ConstraintLayout here allows us to encapsulate the entire menu
          content while keeping the root's dimensions fixed.
    -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <!--
            Seasonal Logo:
            - android:adjustViewBounds="true": Ensures the logo preserves its aspect ratio
              regardless of the image provided at runtime.
            - MenuActivity dynamically selects the drawable (spring_logo, winter_logo, etc.)
              based on the user's preference or current date.
        -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="App Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <!--
            "Missions" Header:
            - Bold, themed typography signals a major content section.
            - textColor="?attr/accent_color": Automatically updates to match the current
              seasonal highlight (e.g., orange for autumn, blue for winter).
        -->
        <TextView
            android:id="@+id/missions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Missions"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/accent_color"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/logo"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <!--
            Goal Slot 1:
            - A nested ConstraintLayout is used as a "data row" to keep the goal description
              and the numeric progress text perfectly aligned horizontally.
            - This allows for dynamic strings of varying lengths without breaking the layout.
        -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/goalContainer1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/missions">

            <!-- Goal Name (e.g., "Find Oak Trees"): Set programmatically by MenuActivity. -->
            <TextView
                android:id="@+id/gameGoal1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent" />

            <!-- Goal Progress (e.g., "3/5"): Positioned with a 4dp gap from the name. -->
            <TextView
                android:id="@+id/goalProgress1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/gameGoal1" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Goal Slot 2: Mirroring the structure of the first goal for visual consistency. -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/goalContainer2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/goalContainer1">

            <TextView
                android:id="@+id/gameGoal2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent" />

            <TextView
                android:id="@+id/goalProgress2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/gameGoal2" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--
            Discovery Hint:
            - Provides crucial gameplay instructions in a smaller, non-intrusive 12sp font.
            - android:textAlignment="center" ensures multi-line hints remain visually balanced.
        -->
        <TextView
            android:id="@+id/missionsInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:text="To &quot;discover&quot; a tree, get within 10 m\nand tap on its dot."
            android:textSize="12sp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/goalContainer2"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <!--
            Theme Selection Row:
            - Groups a label and a Spinner together in a horizontal unit.
            - app:layout_constraintBottom_toBottomOf="parent" on the text ensures it aligns
              centered vertically with the dropdown box.
        -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/selectTheme"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/missionsInfo">

            <TextView
                android:id="@+id/selectThemeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seasonal theme:"
                android:textSize="16sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent" />

            <!--
                Season Spinner:
                - Populated with options like "Spring", "Summer", etc.
                - When a selection is made, MenuActivity triggers a theme refresh and
                  calls Activity.recreate() to apply the new color palette instantly.
            -->
            <Spinner
                android:id="@+id/themeSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/selectThemeText" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--
            Achievements Navigation:
            - style="?android:borderlessButtonStyle": Removes the default button background,
              allowing the accent-colored text to act as a clean, low-emphasis link.
        -->
        <Button
            android:id="@+id/achievementsButton"
            style="?android:borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View achievements"
            android:textColor="?attr/accent_color"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/selectTheme" />

        <!--
            About Button (Secondary Action):
            - Positioned on the left side of the bottom row.
            - layout_marginHorizontal="45dp": Used to push the "About" and "Sign out" buttons
              toward their respective corners while maintaining a wide gutter in the center.
        -->
        <Button
            android:id="@+id/aboutButton"
            style="?android:borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About"
            android:textColor="?attr/accent_color"
            android:textSize="18sp"
            android:layout_marginHorizontal="45dp"
            app:layout_constraintTop_toBottomOf="@id/achievementsButton"
            app:layout_constraintLeft_toLeftOf="parent" />

        <!--
            Sign Out (Tertiary Action):
            - Constraints are pinned to the top of the "About" button to ensure they
              share the same horizontal baseline.
            - Returns a specific result code to MainActivity to trigger the logout sequence.
        -->
        <Button
            android:id="@+id/signOutButton"
            style="?android:borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign out"
            android:textColor="?attr/accent_color"
            android:textSize="18sp"
            android:layout_marginHorizontal="45dp"
            app:layout_constraintTop_toTopOf="@id/aboutButton"
            app:layout_constraintRight_toRightOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
