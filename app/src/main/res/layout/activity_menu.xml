<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:padding="16dp"
    tools:context=".Menu">

    <TextView
        android:id="@+id/missions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Missions"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/logo_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/goalContainer1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/missions"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/gameGoal1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/logo_color"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent" />

        <TextView
            android:id="@+id/goalProgress1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/logo_color"
            android:layout_marginStart="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/gameGoal1" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/goalContainer2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/goalContainer1"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/gameGoal2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/logo_color"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent" />

        <TextView
            android:id="@+id/goalProgress2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/logo_color"
            android:layout_marginStart="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/gameGoal2" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/goalContainer2"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/achievementsButton"
            style="?android:borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trophies"
            android:textColor="?attr/logo_color"
            android:textSize="14sp" />

        <Button
            android:id="@+id/aboutButton"
            style="?android:borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About"
            android:textColor="?attr/logo_color"
            android:textSize="14sp" />

        <Button
            android:id="@+id/signOutButton"
            style="?android:borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign out"
            android:textColor="?attr/logo_color"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
