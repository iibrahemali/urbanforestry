<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_login.xml
    Defines the login screen: title, subtitle, email field, password field with
    show/hide toggle, a Log In button, and a link to the sign-up screen.
    ConstraintLayout is used so each element is positioned relative to the one
    above it, keeping the view hierarchy flat for fast rendering.

    android:background="?attr/background_color" — reads the active seasonal theme so
    the screen color adapts automatically (spring, summer, autumn, winter).

    android:padding="24dp" — 24dp content inset on all four sides.

    "Welcome Back" title:
      textSize="32sp" bold, accent_color — dominant visual anchor establishing hierarchy.
      layout_marginTop="64dp" — pushes the title into the upper third of the screen.

    "Sign in to continue" subtitle:
      textColor="@color/white" — plain white (not accent) keeps it subordinate to the title.

    emailInputLayout (TextInputLayout OutlinedBox):
      boxStrokeColor/hintTextColor="?attr/accent_color" — the border and floating label
      both light up in the seasonal accent color when the field is focused.
      layout_marginTop="48dp" — large gap below the subtitle separates text from form.

    emailEditText (TextInputEditText):
      inputType="textEmailAddress" — triggers the "@" keyboard layout and OS email autocomplete.

    passwordInputLayout:
      passwordToggleEnabled="true" — adds a show/hide eye icon so users can verify their password.
      passwordToggleTint="@color/white" — white eye icon visible against the dark background.

    passwordEditText:
      inputType="textPassword" — masks characters and disables clipboard paste for security.

    loginButton:
      backgroundTint="?attr/accent_color" — filled accent = primary call-to-action on this screen.
      textColor="?attr/background_color" — ensures contrast in all seasonal themes.
      cornerRadius="12dp" — rounded corners used consistently across all app buttons.

    goToSignUp (link TextView):
      textColor="?attr/accent_color" — accent color signals this is a tappable link.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp"
    tools:context=".LoginActivity">

    <!-- "Welcome Back" heading — large accent-colored title that anchors the screen's visual hierarchy -->
    <TextView
        android:id="@+id/loginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Welcome Back"
        android:textColor="?attr/accent_color"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- "Sign in to continue" subtitle — plain white, 16sp, sits 8dp below the title -->
    <TextView
        android:id="@+id/loginSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Sign in to continue"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loginTitle" />

    <!-- Email field wrapper — OutlinedBox draws an animated border that highlights in accent_color on focus -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/emailInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:hint="Email"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/loginSubtitle">

        <!-- inputType="textEmailAddress" triggers the keyboard "@" key and enables OS email autocomplete -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/emailEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password field wrapper — includes a show/hide eye icon (passwordToggleEnabled) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Password"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/emailInputLayout"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/white">

        <!-- inputType="textPassword" masks characters and disables clipboard paste for security -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/passwordEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- "Log In" primary button — filled accent background is the dominant call-to-action on this screen -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="?attr/accent_color"
        android:text="Log In"
        android:textColor="?attr/background_color"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/passwordInputLayout" />

    <!-- "Don't have an account? Sign Up" tappable link — accent color signals interactivity -->
    <TextView
        android:id="@+id/goToSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Don't have an account? Sign Up"
        android:textColor="?attr/accent_color"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loginButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
