<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml
    This layout defines the user interface for the Login screen.
    It utilizes modern Material Design components and ConstraintLayout to create a clean,
    responsive, and seasonal-themed authentication experience.
-->

<!--
    Root Container: ConstraintLayout
    - ConstraintLayout is the primary layout manager here, selected to keep the view hierarchy flat.
      A flat hierarchy reduces the depth of the view tree, allowing the Android system to
      perform measurement and layout operations in a single pass, which significantly improves
      UI performance and smoothness.
    - android:background="?attr/background_color": This is a dynamic theme attribute. It resolves
      to a color specific to the current active seasonal theme (Spring, Summer, Autumn, Winter),
      ensuring the app's overall aesthetic remains cohesive and immersive.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp"
    tools:context=".LoginActivity">

    <!--
        Primary Heading: "Welcome Back"
        - 32sp bold: Establishes clear visual hierarchy as the primary identifier of the screen.
        - textColor="?attr/accent_color": Leverages the seasonal theme's highlight color,
          ensuring the title is prominent and visually engaging.
        - layout_marginTop="64dp": Explicitly pushes the content down to create a comfortable
          visual balance in the upper third of the device screen.
    -->
    <TextView
        android:id="@+id/loginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Welcome Back"
        android:textColor="?attr/accent_color"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Subtitle: "Sign in to continue"
        - textColor="@color/white": Uses a constant high-contrast color to provide a
          subordinate visual element that complements the bold title.
        - Positioned 8dp below the title to maintain a logical thematic group.
    -->
    <TextView
        android:id="@+id/loginSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Sign in to continue"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loginTitle" />

    <!--
        Email Input Container:
        - TextInputLayout (OutlinedBox): A Material Design component that provides
          sophisticated features like floating labels and animated border strokes.
          The OutlinedBox style is particularly effective on dark backgrounds for defining
          clear input boundaries.
        - app:boxStrokeColor="?attr/accent_color": Ensures that the field's border glows
          with the seasonal theme color when focused, providing immediate visual confirmation.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/emailInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:hint="Email"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/loginSubtitle">

        <!--
            - android:inputType="textEmailAddress": Specifically optimizes the soft keyboard
              for email entry by showing the "@" and "." symbols. It also enables the system's
              auto-completion and suggestion services for saved email addresses.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/emailEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        Password Input Container:
        - app:passwordToggleEnabled="true": Adds a clickable icon that allows the user to
          toggle the visibility of their input. This is a critical usability feature that
          helps prevent frustration caused by hidden typos during authentication.
    -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Password"
        android:textColorHint="@color/white"
        app:boxStrokeColor="?attr/accent_color"
        app:hintTextColor="?attr/accent_color"
        app:layout_constraintTop_toBottomOf="@id/emailInputLayout"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/white">

        <!--
            - android:inputType="textPassword": Masks the characters for security and disables
              copying text from the field to protect sensitive information.
        -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/passwordEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/white" />

    </com.google.android.material.textfield.TextInputLayout>

    <!--
        "Log In" Primary Action Button:
        - backgroundTint="?attr/accent_color": The bright background signals that this is the
          most important call-to-action on the screen.
        - android:layout_height="60dp": Provides a large, accessible touch target that exceeds
          standard accessibility guidelines for finger-friendly interaction.
        - android:textColor="?attr/background_color": For accessibility, the button's text
          uses the theme's background color, ensuring maximum contrast and legibility against
          the vibrant accent-colored background.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="?attr/accent_color"
        android:text="Log In"
        android:textColor="?attr/background_color"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/passwordInputLayout" />

    <!--
        "Sign Up" Navigation Link:
        - textColor="?attr/accent_color": Consistent with other interactive elements, the
          accent color signals that this text is a tappable link for navigation.
        - layout_marginTop="24dp": Provides clear separation from the primary button to
          prevent accidental taps.
    -->
    <TextView
        android:id="@+id/goToSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Don't have an account? Sign Up"
        android:textColor="?attr/accent_color"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/loginButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
