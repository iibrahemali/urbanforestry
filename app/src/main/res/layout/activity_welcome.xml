<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_welcome.xml
    This layout defines the splash/welcome screen of the Urban Forestry application.
    It serves as the initial entry point, providing a branded experience while
    the app checks for an existing user session.
-->

<!--
    Root Container: ConstraintLayout
    - ConstraintLayout is used to keep the view hierarchy flat, which is critical for
      splash screens that need to render instantly.
    - android:background="?attr/background_color": Dynamically retrieves the seasonal
      theme background color (e.g., Spring, Summer, Autumn, Winter).
    - android:padding="24dp": Ensures consistent internal spacing across all screen sizes.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp"
    tools:context=".WelcomeActivity">

    <!--
        App Logo: ImageView
        - android:layout_height="0dp": This is a "match_constraint" configuration.
        - By constraining the top to the parent and the bottom to the buttonContainer,
          the logo automatically expands to fill all available vertical space above the buttons.
        - android:scaleType="fitCenter": Preserves the logo's aspect ratio while ensuring
          it fits entirely within the dynamic vertical area.
        - layout_marginBottom="24dp": Provides a distinct visual break before the actions start.
    -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="App Logo"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_title"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Button Container: LinearLayout
        - Positioned at the bottom of the screen with a 76dp margin to avoid interference
          with the system's navigation bar or gesture area.
        - The WelcomeActivity typically fades this container in after a short splash delay.
        - tools:layout_editor_absoluteX="24dp" is a design-time helper for the IDE preview.
    -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="76dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="24dp">

        <!--
            "Map" Button: (Authenticated State)
            - android:visibility="gone": Hidden by default.
            - If WelcomeActivity detects an active Firebase user, it sets this button to
              VISIBLE and hides the Login button, providing a fast path back to the map.
            - backgroundTint="?attr/accent_color": Uses the primary seasonal highlight.
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/gotoMapButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="?attr/accent_color"
            android:text="Map"
            android:textColor="?attr/background_color"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="12dp" />

        <!--
            "Log in" Button: (Guest State)
            - This is the primary call-to-action for logged-out users.
            - layout_height="60dp": Ensures a large, accessible touch target.
            - android:textColor="?attr/background_color": Inverts the background color
              to ensure the text is legible against the bright seasonal accent.
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/goToLoginButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="?attr/accent_color"
            android:text="Log in"
            android:textColor="?attr/background_color"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!--
            "Sign Up" Button: (Secondary Action)
            - style="...Button.OutlinedButton": The outlined style visually signals this
              as a secondary action compared to the solid "Log in" button.
            - app:strokeColor="?attr/accent_color": The border color matches the theme's
              active seasonal accent.
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/goToSignUpButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:text="Sign Up"
            android:textColor="?attr/accent_color"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="?attr/accent_color" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
