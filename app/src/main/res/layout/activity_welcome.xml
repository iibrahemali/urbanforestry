<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_welcome.xml
    Defines the splash/welcome screen. The logo ImageView fills all vertical space
    between the screen top and the button container using height=0dp with four-edge
    constraints. The buttonContainer LinearLayout is pinned to the bottom and contains
    three buttons:
      - gotoMapButton (GONE by default): shown when a user is already logged in
      - goToLoginButton (filled, always shown for logged-out): navigates to LoginActivity
      - goToSignUpButton (outlined): navigates to SignUpActivity

    WelcomeActivity reveals the buttonContainer with a fade-in animation after the
    splash delay — it is declared INVISIBLE (not GONE) so layout space is reserved
    during the splash, preventing a layout jump when buttons appear.

    android:id="@+id/mainLayout" — used by WelcomeActivity's animation code to
    reference the root for measuring or attaching transitions.

    buttonContainer layout_marginBottom="76dp" — lifts the buttons above the gesture
    navigation area on modern Android devices.

    gotoMapButton android:visibility="gone" — hidden by default; WelcomeActivity sets
    it VISIBLE and hides goToLoginButton when FirebaseAuth.getCurrentUser() != null.

    goToSignUpButton style=OutlinedButton — outlined (secondary) style visually contrasts
    with the filled (primary) Log In button directly above it.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp"
    tools:context=".WelcomeActivity">

    <!-- App logo — height=0dp with top/bottom constraints fills the space above the button container.
         fitCenter scaleType preserves the aspect ratio while fitting within the available bounds.
         layout_marginBottom="24dp" adds a gap between the logo and the buttons below it. -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="App Logo"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_title"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Button container pinned to the bottom, lifted 76dp above the navigation bar area.
         WelcomeActivity fades this in after the splash; it is INVISIBLE (not GONE) so
         space is reserved during the animation, preventing a layout jump when it appears. -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="76dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="24dp">

        <!-- "Map" button — shown only when a user is already logged in; GONE by default.
             WelcomeActivity sets this VISIBLE and hides goToLoginButton for returning users. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/gotoMapButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="?attr/accent_color"
            android:text="Map"
            android:textColor="?attr/background_color"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="12dp" />

        <!-- "Log in" button — filled accent style, the primary action for first-time visitors -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/goToLoginButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="?attr/accent_color"
            android:text="Log in"
            android:textColor="?attr/background_color"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <!-- "Sign Up" button — outlined style visually signals it as secondary to the filled Log In above -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/goToSignUpButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:text="Sign Up"
            android:textColor="?attr/accent_color"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="?attr/accent_color" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
