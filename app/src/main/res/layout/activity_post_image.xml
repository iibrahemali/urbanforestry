<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_post_image.xml
    This layout defines the user interface for finalizing a photo-based post.
    It allows the user to preview their captured image and add a descriptive caption
    before uploading it to the community feed.
-->

<!--
    Root Container: ConstraintLayout
    - ConstraintLayout is utilized here to ensure a flat and performant view hierarchy.
      By defining constraints between sibling views, it minimizes the need for nested
      layout passes, leading to smoother UI rendering.
    - android:background="?attr/background_color": Dynamically retrieves the base color
      from the seasonal theme (Spring, Summer, Autumn, Winter) to keep the app
      aesthetically synchronized with the current time of year.
    - android:padding="24dp": Ensures that the content remains readable and accessible
      with a consistent margin from the device's hardware edges.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp">

    <!--
        Title: "Add Caption"
        - 26sp bold: High-level header styling used consistently across the post-creation flow.
        - textColor="?attr/accent_color": Adopts the seasonal highlight color (e.g., green for spring)
          to maintain brand and thematic consistency.
    -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Caption"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Image Preview Card: MaterialCardView
        - layout_height="0dp": This is a "match_constraint" configuration. It allows the
          card to dynamically expand vertically to consume all available space between
           the title header above and the caption input field below.
        - app:cardCornerRadius="16dp": Provides a modern, soft aesthetic.
        - app:cardElevation="8dp": Adds a subtle shadow, making the photo preview appear
          distinct and "raised" above the flat background, emphasizing it as the focal point.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintBottom_toTopOf="@id/captionEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            Photo Preview: ImageView
            - android:scaleType="centerCrop": This ensures the user's photo fills the
              entire card area. It crops the image proportionally rather than
              stretching it, maintaining the original visual integrity of the photo.
            - The content is loaded into this view programmatically in PostImageActivity
              using the Glide library, which also handles image rotation.
        -->
        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Photo Preview" />

    </com.google.android.material.card.MaterialCardView>

    <!--
        Caption Input: EditText
        - android:background="@drawable/text_box": Replaces the standard platform
          underline with a custom rounded rectangle container. This creates a clear
          and distinct "input area" that stands out against the dark seasonal theme.
        - app:layout_constraintBottom_toTopOf="@id/btn_post": Pins the input field directly
          above the primary action button for a logical and linear user flow.
    -->
    <EditText
        android:id="@+id/captionEditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Add a caption..."
        android:textSize="16sp"
        android:background="@drawable/text_box"
        android:padding="16dp"
        android:textColor="@android:color/white"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btn_post"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        "Post" Primary Action: MaterialButton
        - backgroundTint="?attr/accent_color": Signals that this is the primary, most
          important action on the screen.
        - layout_height="60dp": Provides a large, accessible touch target that is
          easy to reach even when the software keyboard is active.
        - app:layout_constraintBottom_toBottomOf="parent": Pins the button to the
          bottom of the screen, ensuring it acts as the "final" step in the flow.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_post"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Post"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/background_color"
        android:backgroundTint="?attr/accent_color"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
