<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_post_image.xml
    Defines the image preview + caption screen that appears after the user takes a photo.
    Layout structure (top to bottom):
      1. "Add Caption" title at the top
      2. MaterialCardView containing the image preview — fills the space between the title and caption field
      3. Caption EditText above the Post button
      4. "Post" MaterialButton pinned to the bottom

    imageCard (MaterialCardView):
      height=0dp with top constraint (below title) + bottom constraint (above captionEditText) =
      the card fills whatever vertical space remains in the middle section.
      cardCornerRadius=16dp and cardElevation=8dp give the image preview a raised, photo-frame feel.

    imagePreview (ImageView):
      scaleType="centerCrop" fills the card completely without leaving blank borders.
      PostImageActivity loads the captured photo into this view using BitmapFactory.

    captionEditText:
      background="@drawable/text_box" — custom rounded rectangle drawable replacing the default underline.
      padding=16dp — comfortable text inset inside the custom background.
      constrained bottom_toTopOf btn_post — always sits directly above the Post button.

    btn_post:
      Pinned to the bottom of the screen with layout_marginBottom=24dp so it is always reachable
      regardless of keyboard state.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp">

    <!-- "Add Caption" title — 26sp bold accent color at the top of the screen -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Caption"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Image preview card — height=0dp fills the space between the title above and the caption field below.
         cardCornerRadius=16dp and cardElevation=8dp give the photo a raised photo-frame appearance. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintBottom_toTopOf="@id/captionEditText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- centerCrop fills the card without distortion; PostImageActivity loads the captured photo here -->
        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Photo Preview" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Caption text input — custom text_box drawable replaces the default underline with a rounded rectangle -->
    <EditText
        android:id="@+id/captionEditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Add a caption..."
        android:textSize="16sp"
        android:background="@drawable/text_box"
        android:padding="16dp"
        android:textColor="@android:color/white"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btn_post"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "Post" button — pinned to the bottom of the screen so it is always reachable above the keyboard -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_post"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Post"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/background_color"
        android:backgroundTint="?attr/accent_color"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
