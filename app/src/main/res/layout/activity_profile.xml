<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_profile.xml
    Defines the profile screen using CoordinatorLayout so the AppBarLayout (toolbar with
    back arrow) and the NestedScrollView (scrollable content) work together: as the user
    scrolls down, the AppBar can collapse and the content scrolls beneath it.

    CoordinatorLayout:
      fitsSystemWindows="true" — the root reserves space for the status bar so the toolbar
      sits below it rather than being partially hidden.

    AppBarLayout + MaterialToolbar:
      background="@android:color/transparent" and elevation="0dp" — no visible app bar
      background; only the back arrow and "Profile" title are shown.
      navigationIcon="?attr/homeAsUpIndicator" — the system back-arrow icon, tinted accent_color.
      The "Profile" title is a custom TextView inside the Toolbar (not setTitle()) so it can
      be styled with accent_color, 18sp, bold.

    NestedScrollView:
      app:layout_behavior="@string/appbar_scrolling_view_behavior" — tells CoordinatorLayout
      that this scroll view should scroll in coordination with the AppBarLayout above it.

    Inner LinearLayout (gravity=center_horizontal, orientation=vertical, padding=24dp):
      Centers all profile content horizontally and stacks it vertically.

    Profile image (MaterialCardView + ImageView):
      120×120dp MaterialCardView with cardCornerRadius=60dp = perfect circle.
      strokeColor/strokeWidth draws the accent-colored ring border.
      ImageView inside uses scaleType="centerCrop" so photos fill the circle without distortion.
      android:background="#123D24" — dark green fill shows while the image loads via Glide.

    statsCard (MaterialCardView):
      cardBackgroundColor="?attr/accent_color" — the entire card is filled with the accent color.
      Contains a horizontal LinearLayout with two equal-weight columns (likes count + posts count)
      separated by a 1dp semi-transparent vertical divider (alpha=0.3).

    profileBio (TextView):
      gravity="center" — bio text is centered, lineSpacingExtra=4dp for readability.
      textColor="?attr/alt_color" — slightly different from accent gives it secondary prominence.

    editProfileButton:
      style=OutlinedButton — secondary action, less prominent than the filled Back button.

    backButton:
      style=Widget.MaterialComponents.Button with backgroundTint=accent_color — primary filled
      button, visually the "safe exit" action on this screen.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/background_color">

    <!-- AppBarLayout + Toolbar: transparent background with accent-colored back arrow and "Profile" title -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!-- MaterialToolbar hosts the back-arrow navigation icon and a custom title TextView -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="?attr/accent_color">

            <!-- Custom title TextView inside the toolbar so it can be styled with accent_color and bold -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="?attr/accent_color"
                android:textSize="18sp"
                android:textStyle="bold" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable profile content — appbar_scrolling_view_behavior coordinates with the AppBarLayout above -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Vertical column of profile elements, all centered horizontally -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Profile image: 120×120dp circular card with accent stroke — Glide loads the real image into profileImage -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="8dp"
                app:strokeColor="?attr/accent_color"
                app:strokeWidth="2dp">

                <!-- scaleType="centerCrop" fills the circle with the photo; dark green background shows while loading -->
                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/default_pfp"
                    android:background="#123D24"
                    android:contentDescription="Profile Picture" />

            </com.google.android.material.card.MaterialCardView>

            <!-- User's full name — 26sp bold white, 20dp below the profile image -->
            <TextView
                android:id="@+id/accountName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                tools:text="Full Name"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- @username — 16sp accent color, 4dp below the full name -->
            <TextView
                android:id="@+id/username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                tools:text="@username"
                android:textColor="?attr/accent_color"
                android:textSize="16sp" />

            <!-- Stats card: horizontal row with Likes count on the left and Posts count on the right,
                 separated by a 1dp semi-transparent vertical line.
                 cardBackgroundColor=accent_color fills the entire card with the seasonal theme color. -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="?attr/accent_color"
                app:strokeColor="?attr/accent_color"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <!-- Horizontal row containing two equal-weight stat columns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <!-- Left column: total likes received across all the user's posts -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- Likes count number — set by ProfileActivity after querying Firestore -->
                        <TextView
                            android:id="@+id/likesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="?attr/background_color"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <!-- "LIKES" label — small all-caps caption below the number -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="Likes"
                            android:textAllCaps="true"
                            android:textColor="?attr/background_color"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Vertical divider between the two stat columns — 30dp tall, 30% opacity -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:background="?attr/background_color"
                        android:alpha="0.3" />

                    <!-- Right column: total number of posts created by this user -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- Posts count number — set by ProfileActivity after querying Firestore -->
                        <TextView
                            android:id="@+id/postsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="?attr/background_color"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <!-- "POSTS" label — small all-caps caption below the number -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Posts"
                            android:textColor="?attr/background_color"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- User bio text — centered, alt_color, lineSpacingExtra=4dp for comfortable multi-line reading -->
            <TextView
                android:id="@+id/profileBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                tools:text="User biography goes here..."
                android:textColor="?attr/alt_color"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <!-- "Edit Profile" button — outlined (secondary) style because editing is less common than just viewing -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/editProfileButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Edit Profile"
                android:textSize="18sp"
                android:textColor="?attr/accent_color"
                app:strokeColor="?attr/accent_color"
                app:cornerRadius="12dp" />

            <!-- "Back" button — filled accent style is the primary/safe action to close this screen -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="Back"
                android:textSize="18sp"
                android:backgroundTint="?attr/accent_color"
                android:textColor="?attr/background_color"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
