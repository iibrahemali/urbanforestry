<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_profile.xml
    This layout defines the user profile screen. It uses a CoordinatorLayout to manage
    sophisticated interactions between the App Bar and the scrollable content.
-->

<!--
    Root Container: CoordinatorLayout
    - CoordinatorLayout is a powerful frame that coordinates interactions between child views.
      Specifically, it allows the AppBarLayout to react to scroll events from the NestedScrollView.
    - android:fitsSystemWindows="true": This ensures that the layout is correctly inset
      behind system UI components like the status bar, preventing content overlap.
    - android:background="?attr/background_color": Dynamically retrieves the base color
      from the seasonal theme to ensure visual continuity.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/background_color">

    <!--
        AppBarLayout:
        - A vertical LinearLayout that implements Material Design app bar features like
          collapsing and elevation changes.
        - app:elevation="0dp": Removes the default shadow to maintain a flat, modern
          look for the profile header.
    -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!--
            MaterialToolbar:
            - Hosts the navigation "back" arrow and the screen title.
            - app:navigationIconTint="?attr/accent_color": Ensures the back arrow color
              matches the current seasonal theme.
        -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="?attr/accent_color">

            <!--
                Custom Toolbar Title:
                - Using a TextView inside the toolbar allows for specific styling (bold,
                  accent color) that standard toolbar titles may not support as easily.
            -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="?attr/accent_color"
                android:textSize="18sp"
                android:textStyle="bold" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!--
        NestedScrollView:
        - Wraps the main profile content to allow scrolling on smaller screens.
        - app:layout_behavior="@string/appbar_scrolling_view_behavior": This is a
          crucial attribute. It tells CoordinatorLayout that this view should be
          positioned below the AppBarLayout and should coordinate its scrolling with it.
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!--
            Content Container:
            - A vertical LinearLayout centers all profile elements horizontally.
            - android:padding="24dp" provides consistent internal spacing.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!--
                Profile Image Frame: MaterialCardView
                - 120dp square frame.
                - app:cardCornerRadius="60dp": Setting the radius to exactly 50% of the
                  width/height creates a perfect circle.
                - app:strokeWidth="2dp": Adds a branded ring around the photo in the
                  seasonal accent color.
            -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="8dp"
                app:strokeColor="?attr/accent_color"
                app:strokeWidth="2dp">

                <!--
                    Profile Image:
                    - android:scaleType="centerCrop": Ensures the photo fills the entire
                      circular frame without being stretched.
                    - android:background="#123D24": A placeholder color that shows
                      before the real image is loaded from Firebase/Glide.
                -->
                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/default_pfp"
                    android:background="#123D24"
                    android:contentDescription="Profile Picture" />

            </com.google.android.material.card.MaterialCardView>

            <!--
                User Name:
                - Large 26sp bold white text for high visibility.
            -->
            <TextView
                android:id="@+id/accountName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                tools:text="Full Name"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!--
                Username Handle:
                - Small 16sp text using the seasonal accent color to distinguish it
                  from the full name.
            -->
            <TextView
                android:id="@+id/username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                tools:text="@username"
                android:textColor="?attr/accent_color"
                android:textSize="16sp" />

            <!--
                Stats Card:
                - Provides a visual summary of user activity (Likes and Posts).
                - app:cardBackgroundColor="?attr/accent_color": Inverts the theme by
                  using the accent color as the background, making this section pop.
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="?attr/accent_color"
                app:strokeColor="?attr/accent_color"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <!--
                    Stats Row:
                    - Uses a horizontal LinearLayout to split the card into two sections.
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <!--
                        Likes Column:
                        - android:layout_weight="1": Ensures the column takes up exactly
                          50% of the available horizontal space.
                    -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- Value is dynamically updated in ProfileActivity. -->
                        <TextView
                            android:id="@+id/likesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="?attr/background_color"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="Likes"
                            android:textAllCaps="true"
                            android:textColor="?attr/background_color"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!--
                        Vertical Divider:
                        - A 1dp line with reduced alpha (0.3) provides a subtle visual
                          separation between stats without being distracting.
                    -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:background="?attr/background_color"
                        android:alpha="0.3" />

                    <!--
                        Posts Column:
                        - Also weighted 1 to mirror the Likes column.
                    -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/postsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="?attr/background_color"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Posts"
                            android:textColor="?attr/background_color"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--
                User Bio:
                - android:lineSpacingExtra="4dp": Adds vertical breathing room between
                  lines of text, which is vital for readability in longer biographies.
                - android:textColor="?attr/alt_color": Uses a slightly muted accent
                  color to differentiate the bio from primary headers.
            -->
            <TextView
                android:id="@+id/profileBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                tools:text="User biography goes here..."
                android:textColor="?attr/alt_color"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <!--
                Secondary Action: Edit Profile
                - style="...Button.OutlinedButton": This outlined style visually
                  signals that it is a less frequent or secondary action compared
                  to the primary "Back" button.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/editProfileButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Edit Profile"
                android:textSize="18sp"
                android:textColor="?attr/accent_color"
                app:strokeColor="?attr/accent_color"
                app:cornerRadius="12dp" />

            <!--
                Primary Action: Back
                - style="...Widget.MaterialComponents.Button": A filled button with
                  seasonal backgroundTint indicates the primary path to exit the screen.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="Back"
                android:textSize="18sp"
                android:backgroundTint="?attr/accent_color"
                android:textColor="?attr/background_color"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
