<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_achievements.xml
    This layout defines the "Achievements" screen, which showcases the user's progress.
    It utilizes a ConstraintLayout as the primary container to maintain a flat and efficient
    view hierarchy, which is crucial for complex screens.
-->

<!--
    Root Container: ConstraintLayout
    - android:padding="16dp": Adds standard spacing around the edge of the screen.
    - android:background="?attr/background_color": Dynamically retrieves the background color
      defined in the current seasonal theme (e.g., deep blue for winter, soft green for spring).
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="?attr/background_color"
    tools:context=".AchievementsActivity">

    <!--
        Title Header: "My Achievements"
        - 26sp bold text: Follows standard Material Design typography for top-level headers.
        - textColor="?attr/accent_color": Ensures the text remains visible and aesthetically consistent
          with the app's seasonal theme accents.
        - layout_marginTop="35dp": Provides a distinct visual break from the top system bar.
    -->
    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Achievements"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="35dp"
        android:textColor="?attr/accent_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Achievement List: RecyclerView
        - android:layout_height="0dp": This is "match_constraint". It allows the list to
          dynamically expand to fill all available vertical space between the title and the button.
        - app:layout_constraintTop_toBottomOf="@id/titleHeader": Anchors the top of the list to the title.
        - app:layout_constraintBottom_toTopOf="@id/backButton": Pins the bottom to the back button,
          ensuring the list doesn't overlap the primary navigation action.
        - RecyclerView is more efficient than ListView because it recycles view holders,
          keeping memory usage low even with long lists of trophies.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/achievementRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/titleHeader"
        app:layout_constraintBottom_toTopOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Back Button: MaterialButton
        - android:layout_height="60dp": Ensures a large, accessible touch target for better usability.
        - app:cornerRadius="12dp": Provides a modern, rounded aesthetic consistent with other Material components.
        - android:backgroundTint="?attr/accent_color": Uses the seasonal theme's primary accent color.
        - android:textColor="?attr/background_color": Inverts the theme background color to ensure
          the button text has high contrast and is easy to read against the tinted background.
        - app:layout_constraintBottom_toBottomOf="parent": Pins the button to the bottom of the screen.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/backButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:text="Back to Map"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        android:textColor="?attr/background_color"
        android:backgroundTint="?attr/accent_color"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
