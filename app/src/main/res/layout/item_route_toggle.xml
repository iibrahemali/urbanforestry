<?xml version="1.0" encoding="utf-8"?>
<!--
    item_route_toggle.xml
    This file defines a specialized circular toggle button used for map route navigation.
    Each instance represents a specific route (e.g., "Oak Trail") and allows users
    to toggle that route's visibility on the OSM map.
-->

<!--
    Standalone MaterialButton:
    - This view is designed to be inflated programmatically by Routes.java and added
      to a vertical LinearLayout (routeControlsContainer) on the right side of the map.
    - android:layout_width/height="50dp": Provides a compact yet accessible touch target.
    - app:cornerRadius="25dp": Setting the radius to exactly 50% of the dimensions
      transforms the standard rectangular button into a perfect circle.
    - android:insetTop/Bottom/Left/Right="0dp": Critical detail. Material buttons have
      default insets to allow for shadows. Setting these to 0 ensures the button
      occupies the full 50x50dp space and maintains its circular shape without distortion.
    - app:backgroundTint="?attr/accent_color": The default color matches the season,
      but Routes.java programmatically overrides this with a unique color that matches
      the specific Polyline drawn on the map.
    - app:strokeWidth="2dp" and app:strokeColor="@android:color/black": Adds a distinct
      border to ensure the button remains visible regardless of the map's terrain colors.
    - app:icon="@drawable/ic_route": Provides immediate visual context that this
      button controls a navigation path.
    - app:iconGravity="textStart" and app:iconPadding="0dp": In a button with no text,
      this configuration centers the icon perfectly within the circular bounds.
-->
<com.google.android.material.button.MaterialButton xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/btn_toggle_route"
    android:layout_width="50dp"
    android:layout_height="50dp"
    android:layout_marginBottom="8dp"
    android:insetLeft="0dp"
    android:insetTop="0dp"
    android:insetRight="0dp"
    android:insetBottom="0dp"
    app:cornerRadius="25dp"
    android:padding="0dp"
    app:icon="@drawable/ic_route"
    app:iconTint="@color/white"
    app:iconSize="24dp"
    app:iconGravity="textStart"
    app:iconPadding="0dp"
    app:backgroundTint="?attr/accent_color"
    app:strokeColor="@android:color/black"
    app:strokeWidth="2dp" />
