<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    This layout defines the primary interactive map screen, which serves as the core of
    the Urban Forestry application. It overlays interactive navigation and control
    elements on top of a full-screen geographic map.
-->

<!--
    Root Container: ConstraintLayout
    - This layout manager is used to maintain a flat view hierarchy. By avoiding nested layouts,
      the measurement and layout passes are optimized for performance, which is especially
      important when rendering a heavy component like a MapView.
    - android:id="@+id/main" provides a reference for programmatic UI adjustments or animations.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!--
        Full-screen osmdroid MapView:
        - Positioned first in the XML so it renders at the lowest Z-index (beneath all other views).
        - android:layout_width/height="match_parent" ensures the map fills the entire device display.
        - All subsequent ImageButtons and UI containers will float "above" this layer.
    -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        Menu Button (Top-Left Corner):
        - android:background="@drawable/round_button": Uses a custom shape drawable to provide
          a consistent circular aesthetic for all map overlays.
        - android:src="@drawable/ic_menu": Displays the hamburger icon.
        - app:tint="?attr/background_color": Dynamically inverts the icon color based on the
          seasonal theme to ensure visibility against the primary button background.
        - app:layout_constraintLeft_toLeftOf="parent" and app:layout_constraintTop_toTopOf="parent":
          Pins the button relative to the top-left screen boundary with a 16dp margin for ergonomics.
    -->
    <ImageButton
        android:id="@+id/menuButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:background="@drawable/round_button"
        android:src="@drawable/ic_menu"
        android:scaleType="fitCenter"
        android:padding="10dp"
        app:tint="?attr/background_color"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Feed Button (Top-Right Corner):
        - Follows the same design pattern as the menu button for visual consistency.
        - android:src="@drawable/ic_social": Represents the community social feed.
        - Pins to the top-right corner, mirroring the menu button's positioning logic.
    -->
    <ImageButton
        android:id="@+id/feedButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:background="@drawable/round_button"
        android:src="@drawable/ic_social"
        android:scaleType="fitCenter"
        android:padding="10dp"
        app:tint="?attr/background_color"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Route Controls Scroll Container (Right-Side Column):
        - This container holds dynamic toggle buttons for different map routes.
        - android:layout_height="0dp" (match_constraint): Allows the column to expand
          vertically between the bottom of the feed button and the bottom of the screen.
        - android:scrollbars="none": Keeps the narrow side column visually clean while
          still allowing users to swipe through a large list of active routes.
    -->
    <ScrollView
        android:id="@+id/routeScrollView"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/feedButton">

        <!--
            routeControlsContainer (LinearLayout):
            - Acts as the target for dynamic view inflation.
            - Routes.java finds this container by ID and programmatically adds
              'item_route_toggle' views for each active forestry route.
            - android:orientation="vertical" ensures the toggles stack neatly in a column.
        -->
        <LinearLayout
            android:id="@+id/routeControlsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
