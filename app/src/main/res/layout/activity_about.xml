<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_about.xml
    This layout defines the "About" screen of the Urban Forestry application.
    It provides information about the department, staff contact details, and social media links.
-->

<!--
    Root: NestedScrollView
    Wraps all content to allow vertical scrolling on smaller devices or in landscape mode.
    Unlike standard ScrollView, it supports nested scrolling behaviors which is useful for future
    complex interactions.
    android:background="?attr/background_color" — Uses a theme attribute to dynamically
    set the background based on the current season (Spring, Summer, Autumn, Winter).
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="?attr/background_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AboutActivity">

    <!--
        ConstraintLayout: Flat view hierarchy for optimized rendering.
        Each element is constrained relative to others or the parent to maintain consistent positioning.
        android:layout_height="wrap_content" — Ensures the layout expands to fit all children inside the ScrollView.
    -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!--
            App Title: "MyCelia"
            The textColor "?attr/accent_color" ensures it adopts the seasonal primary color.
            Horizontal centering is achieved by constraining start and end to parent.
        -->
        <TextView
            android:id="@+id/about_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MyCelia"
            android:textColor="?attr/accent_color"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            Department Description:
            Uses 0dp width with start/end constraints to wrap text properly across the screen.
            Center alignment helps create a professional, balanced look.
        -->
        <TextView
            android:id="@+id/about_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="This app belongs to Lancaster's Urban Forestry department"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/about_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            Lancaster City Logo:
            android:adjustViewBounds="true" ensures the aspect ratio is maintained when height is fixed (120dp).
            android:scaleType="fitCenter" centers and scales the image within the view.
        -->
        <ImageView
            android:id="@+id/about_logo"
            android:layout_width="wrap_content"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/lancaster_logo"
            android:contentDescription="Lancaster Logo"
            app:layout_constraintTop_toBottomOf="@id/about_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            "Contacts" Header:
            A larger separator label to organize information logically.
            Top margin of 32dp provides distinct breathing room from the imagery above.
        -->
        <TextView
            android:id="@+id/contacts_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contacts"
            android:textColor="?attr/accent_color"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/about_logo"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            Staff Name: Michael Meyer
            White text provides high contrast against the seasonal background.
        -->
        <TextView
            android:id="@+id/name_michael"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Michael Meyer"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/contacts_header"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            Job Title:
            Uses "?attr/alt_color" for a secondary accent, creating a subtle visual hierarchy
            between the name and the professional role.
        -->
        <TextView
            android:id="@+id/title_michael"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Urban Forester"
            android:textColor="?attr/alt_color"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/name_michael"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            Phone Number Link:
            android:clickable="true" and android:focusable="true" indicate this is an interactive element.
            The primary accent color tells the user this text performs an action (dialing).
        -->
        <TextView
            android:id="@+id/phone_michael"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(717) 517-0864"
            android:textColor="?attr/accent_color"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/title_michael"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            Email Link:
            Styled consistently with the phone number to denote a tappable communication link.
        -->
        <TextView
            android:id="@+id/email_michael"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mmeyer@cityoflancasterpa.gov"
            android:textColor="?attr/accent_color"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/phone_michael"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            Second Staff Member: Rick Anderer
            24dp top margin spaces individual contact entries clearly.
        -->
        <TextView
            android:id="@+id/name_rick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rick Anderer"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/email_michael"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/title_rick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City Arborist"
            android:textColor="?attr/alt_color"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/name_rick"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/phone_rick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(717) 291-4846"
            android:textColor="?attr/accent_color"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/title_rick"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/email_rick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="randerer@cityoflancasterpa.gov"
            android:textColor="?attr/accent_color"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/phone_rick"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            "Follow Us" Section Header:
            Consistent style and spacing with the "Contacts" section for UI uniformity.
        -->
        <TextView
            android:id="@+id/social_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Follow Us"
            android:textColor="?attr/accent_color"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/email_rick"
            app:layout_constraintStart_toStartOf="parent" />

        <!--
            Social Media Button Row:
            Horizontal LinearLayout centered within the screen.
            Grouping icons here makes it easier to manage their layout than individual constraints.
        -->
        <LinearLayout
            android:id="@+id/social_icons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/social_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!--
                Social ImageButton Template (LinkedIn):
                - 64dp square touch target for easy interaction.
                - Borderless background ripple for a modern feel.
                - Icon tinted with "?attr/accent_color" to keep the palette cohesive.
                - Mandatory contentDescription for screen reader accessibility.
            -->
            <ImageButton
                android:id="@+id/btn_linkedin"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_linkedin"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="8dp"
                app:tint="?attr/accent_color"
                android:contentDescription="LinkedIn" />

            <!--
                YouTube Button:
                Separated by 16dp horizontal margin for visual clarity.
            -->
            <ImageButton
                android:id="@+id/btn_youtube"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_youtube"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="8dp"
                app:tint="?attr/accent_color"
                android:layout_marginStart="16dp"
                android:contentDescription="YouTube" />

            <!-- Instagram Button -->
            <ImageButton
                android:id="@+id/btn_instagram"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_instagram"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="8dp"
                app:tint="?attr/accent_color"
                android:layout_marginStart="16dp"
                android:contentDescription="Instagram" />

            <!-- Facebook Button -->
            <ImageButton
                android:id="@+id/btn_facebook"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_facebook"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:padding="8dp"
                app:tint="?attr/accent_color"
                android:layout_marginStart="16dp"
                android:contentDescription="Facebook" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
