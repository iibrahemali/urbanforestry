<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_post_text.xml
    This layout defines the user interface for composing a text-only community post.
    It focuses on a simple, distraction-free environment for writing content.
-->

<!--
    Root Container: ConstraintLayout
    - ConstraintLayout is the preferred layout manager for modern Android apps. It enables
      the creation of large and complex layouts with a flat view hierarchy.
    - Flat hierarchies are significantly more performant because they reduce the number
      of nested measurement and layout passes the system must perform.
    - android:background="?attr/background_color": Dynamically retrieves the background
      color from the seasonal theme, ensuring the composition experience remains
      visually consistent with the rest of the app's current season.
    - android:padding="24dp": Standardized internal spacing to prevent content from
      touching the physical screen edges.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background_color"
    android:padding="24dp">

    <!--
        Title: "Write a Post"
        - 26sp bold: High-level header styling used consistently across the creation flow.
        - textColor="?attr/accent_color": Matches the primary seasonal highlight color.
        - layout_marginTop="64dp": Provides generous whitespace above the header to
          avoid conflict with status bar elements.
    -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Write a Post"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="?attr/accent_color"
        android:layout_marginTop="64dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Post Content Field: EditText
        - android:layout_height="350dp": Provides a large, dedicated area for writing.
        - android:gravity="top|start": This is a critical multiline detail; it ensures the
          cursor and text start at the top-left rather than being vertically centered.
        - android:background="@drawable/text_box": Replaces the standard underline with a
          themed container, creating a distinct "paper-like" area for composition.
        - android:padding="16dp": Inset spacing within the text box for better legibility.
    -->
    <EditText
        android:id="@+id/editText"
        android:layout_width="0dp"
        android:layout_height="350dp"
        android:hint="What's on your mind?"
        android:textSize="16sp"
        android:background="@drawable/text_box"
        android:padding="16dp"
        android:gravity="top|start"
        android:textColor="@color/white"
        android:layout_marginVertical="24dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintBottom_toTopOf="@id/btn_post"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        "Post" Primary Action: MaterialButton
        - backgroundTint="?attr/accent_color": Signals that this is the primary action.
        - layout_height="60dp": High-visibility, accessible touch target.
        - app:layout_constraintBottom_toBottomOf="parent": Pins the button to the bottom.
          In many cases, the OS will push this button up when the software keyboard
          appears, keeping the primary action always reachable.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_post"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Post"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/background_color"
        android:backgroundTint="?attr/accent_color"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="48dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
