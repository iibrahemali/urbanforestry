<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UrbanForestry" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Default attribute values to prevent crashes if a specific theme is missing them -->
        <item name="background_color">@color/summer_background_color</item>
        <item name="logo_color">@color/summer_logo_color</item>
        <item name="android:windowBackground">?attr/background_color</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.UrbanForestry" parent="Base.Theme.UrbanForestry" />

    <!-- Seasonal Themes -->
    <style name="Theme.UrbanForestry.Summer" parent="Theme.UrbanForestry">
        <item name="background_color">@color/summer_background_color</item>
        <item name="logo_color">@color/summer_logo_color</item>
    </style>

    <style name="Theme.UrbanForestry.Winter" parent="Theme.UrbanForestry">
        <item name="background_color">@color/winter_background_color</item>
        <item name="logo_color">@color/winter_logo_color</item>
    </style>

    <style name="Theme.UrbanForestry.Autumn" parent="Theme.UrbanForestry">
        <item name="background_color">@color/autumn_background_color</item>
        <item name="logo_color">@color/autumn_logo_color</item>
    </style>

    <style name="Theme.UrbanForestry.Spring" parent="Theme.UrbanForestry">
        <item name="background_color">@color/spring_background_color</item>
        <item name="logo_color">@color/spring_logo_color</item>
    </style>

    <!-- Dialog Themes -->
    <style name="Theme.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowNoTitle">true</item>
        <item name="windowNoTitle">true</item>
        <!-- Ensure dialogs also have these attributes defined -->
        <item name="background_color">@color/summer_background_color</item>
        <item name="logo_color">@color/summer_logo_color</item>
        <item name="android:windowBackground">?attr/background_color</item>
    </style>

    <!-- Seasonal Dialog Themes -->
    <style name="Theme.UrbanForestry.Dialog.Summer" parent="Theme.Dialog">
        <item name="background_color">@color/summer_background_color</item>
        <item name="logo_color">@color/summer_logo_color</item>
    </style>

    <style name="Theme.UrbanForestry.Dialog.Winter" parent="Theme.Dialog">
        <item name="background_color">@color/winter_background_color</item>
        <item name="logo_color">@color/winter_logo_color</item>
    </style>

    <style name="Theme.UrbanForestry.Dialog.Autumn" parent="Theme.Dialog">
        <item name="background_color">@color/autumn_background_color</item>
        <item name="logo_color">@color/autumn_logo_color</item>
    </style>

    <style name="Theme.UrbanForestry.Dialog.Spring" parent="Theme.Dialog">
        <item name="background_color">@color/spring_background_color</item>
        <item name="logo_color">@color/spring_logo_color</item>
    </style>

    <style name="ShapeAppearance.UrbanForestry.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="DeleteBottomSheetStyle" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/DeleteBottomSheet</item>
    </style>

    <style name="DeleteBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@drawable/bottom_sheet_bg</item>
    </style>

    <!-- Splash Screen Themes -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/summer_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.UrbanForestry</item>
    </style>

    <style name="Theme.App.Starting.Summer" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/summer_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_title</item>
        <item name="postSplashScreenTheme">@style/Theme.UrbanForestry.Summer</item>
    </style>

    <style name="Theme.App.Starting.Winter" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/winter_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/winter_logo_title</item>
        <item name="postSplashScreenTheme">@style/Theme.UrbanForestry.Winter</item>
    </style>

    <style name="Theme.App.Starting.Autumn" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/autumn_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/autumn_logo_title</item>
        <item name="postSplashScreenTheme">@style/Theme.UrbanForestry.Autumn</item>
    </style>

    <style name="Theme.App.Starting.Spring" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/spring_splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/spring_logo_title</item>
        <item name="postSplashScreenTheme">@style/Theme.UrbanForestry.Spring</item>
    </style>
</resources>
