<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UrbanForestry" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_color</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Theme.UrbanForestry" parent="Base.Theme.UrbanForestry" />

    <style name="Theme.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowNoTitle">true</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ShapeAppearance.UrbanForestry.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="DeleteBottomSheetStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/DeleteBottomSheet</item>
    </style>

    <style name="DeleteBottomSheet" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bottom_sheet_bg</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.UrbanForestry</item>
    </style>
</resources>
